# Google Docs template ID.
# Example URL: https://docs.google.com/document/d/TEMPLATE_DOC_ID/edit
TEMPLATE_DOC_ID="replace_with_google_docs_template_id"

# Google Drive destination folder ID.
# Example URL: https://drive.google.com/drive/folders/DESTINATION_FOLDER_ID
DESTINATION_FOLDER_ID="replace_with_google_drive_folder_id"

# Full JSON from the Google Cloud service account key.
# Keep this value in one line when using it as an environment variable.
GOOGLE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"replace_with_project_id","private_key_id":"replace_with_private_key_id","private_key":"-----BEGIN PRIVATE KEY-----\\nreplace_with_private_key\\n-----END PRIVATE KEY-----\\n","client_email":"replace_with_service_account_email","client_id":"replace_with_client_id","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"replace_with_client_x509_cert_url","universe_domain":"googleapis.com"}'

# Optional OAuth credentials for personal Drive / My Drive.
# If these three values are present, the script uses OAuth instead of service account auth.
GOOGLE_OAUTH_CLIENT_ID="replace_with_oauth_client_id"
GOOGLE_OAUTH_CLIENT_SECRET="replace_with_oauth_client_secret"
GOOGLE_OAUTH_REFRESH_TOKEN="replace_with_oauth_refresh_token"
